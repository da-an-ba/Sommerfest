---
import unicornHi from '../assets/unicorns/unicorn-hi.png';
// ← Passwort hier ändern
const PASSWORD = 'einhorn2025';
---

<div id="gate" role="dialog" aria-modal="true" aria-label="Passwortschutz">
  <div class="gate-orb gate-orb-1"></div>
  <div class="gate-orb gate-orb-2"></div>
  <div class="gate-box">
    <img src={unicornHi.src} alt="" class="gate-unicorn" />
    <h2 class="gate-title">Nur für Eingeladene</h2>
    <p class="gate-sub">Gib das Passwort ein, um zur Party zu kommen.</p>
    <form id="gate-form" novalidate>
      <input id="gate-input" type="password" placeholder="Passwort"
             autocomplete="current-password" autofocus />
      <button id="gate-btn" type="submit">Rein da →</button>
    </form>
    <p id="gate-error" aria-live="polite"></p>
  </div>
</div>

<style>
  #gate {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: radial-gradient(ellipse at 20% 30%, #3b0764 0%, transparent 60%),
                radial-gradient(ellipse at 80% 70%, #0c4a6e 0%, transparent 60%),
                var(--dark);
    overflow: hidden;
  }

  .gate-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    animation: pulse 9s ease-in-out infinite;
  }
  .gate-orb-1 { width: 400px; height: 400px; background: var(--pink); opacity: .3; top: -15%; left: -10%; }
  .gate-orb-2 { width: 350px; height: 350px; background: var(--cyan); opacity: .25; bottom: -10%; right: -5%; animation-delay: -4s; }

  .gate-box {
    position: relative;
    z-index: 1;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    backdrop-filter: blur(20px);
    border-radius: 2rem;
    padding: 2.8rem 2.4rem 2.4rem;
    width: 100%;
    max-width: 400px;
    text-align: center;
  }

  .gate-unicorn { display: block; width: 110px; height: 110px; object-fit: contain; margin: 0 auto .8rem; }
  .gate-title { font-size: 1.6rem; font-weight: 900; color: #fff; margin-bottom: .4rem; }
  .gate-sub   { font-size: .9rem; font-weight: 600; color: rgba(255,255,255,.5); margin-bottom: 1.8rem; }

  #gate-form { display: flex; flex-direction: column; gap: .75rem; }

  #gate-input {
    width: 100%;
    padding: .85rem 1.2rem;
    border-radius: 1rem;
    border: 1.5px solid rgba(255,255,255,.15);
    background: rgba(255,255,255,.08);
    color: #fff;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    outline: none;
    transition: border-color .2s;
    text-align: center;
    letter-spacing: .1rem;
  }
  #gate-input::placeholder { color: rgba(255,255,255,.3); letter-spacing: 0; }
  #gate-input:focus        { border-color: var(--violet); }

  #gate-btn {
    width: 100%;
    padding: .85rem;
    border-radius: 1rem;
    border: none;
    background: linear-gradient(90deg, var(--pink), var(--violet));
    color: #fff;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 900;
    cursor: pointer;
    transition: opacity .2s, transform .2s;
  }
  #gate-btn:hover  { opacity: .9; transform: translateY(-2px); }
  #gate-btn:active { transform: translateY(0); }

  #gate-error {
    margin-top: .6rem;
    font-size: .82rem;
    font-weight: 700;
    color: #fca5a5;
    min-height: 1.2em;
  }

  .shake { animation: shake .4s ease; }
</style>

<script define:vars={{ PASSWORD }}>
  const gate = document.getElementById('gate');

  if (sessionStorage.getItem('unlocked') === '1') {
    gate.remove();
    document.body.classList.remove('locked');
  } else {

  function unlock() {
    sessionStorage.setItem('unlocked', '1');
    gate.style.transition = 'opacity .5s ease';
    gate.style.opacity = '0';
    setTimeout(() => { gate.remove(); document.body.classList.remove('locked'); }, 500);
  }

  document.getElementById('gate-form').addEventListener('submit', e => {
    e.preventDefault();
    const input = document.getElementById('gate-input');
    if (input.value.trim() === PASSWORD) {
      unlock();
    } else {
      document.getElementById('gate-error').textContent = 'Falsches Passwort — probier nochmal!';
      input.classList.remove('shake');
      void input.offsetWidth;
      input.classList.add('shake');
      input.value = '';
      input.focus();
    }
  });

  } // end else
</script>
