---
import unicornSummer from '../assets/unicorns/unicorn-summer.png';
---
<section id="start" class="section location-section">
  <div class="section-inner" style="text-align:center">
    <img src={unicornSummer.src} alt="" class="section-unicorn reveal" />
    <p class="eyebrow reveal">📍 Der Ort des Geschehens</p>
    <h2 class="location-name reveal reveal-delay-1">
      Pleikartsförster<span class="accent"> Hof 9</span>
    </h2>
    <p class="location-sub reveal reveal-delay-2">
      Unser Garten ist nicht riesig, aber gemütlich — mit viel Grün,
      Schatten, und genug Platz zum Toben, Malen und Planschen.
    </p>
    <div class="location-tags reveal reveal-delay-3">
      <span class="tag">🌿 Gemütlicher Garten</span>
      <span class="tag">🐄 Tierisch gute Atmosphäre</span>
      <span class="tag">🧺 Bring-dein-Handtuch-Zone</span>
      <span class="tag">🔥 Grill wird gestellt</span>
    </div>
  </div>
</section>

<style>
  .location-section { background: var(--light); }

  .location-name {
    font-size: clamp(2.4rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1;
    color: #1e0d4a;
    margin-top: .5rem;
  }
  .location-name .accent { color: var(--pink); }

  .location-sub {
    margin-top: 1rem;
    color: #7c6a9a;
    font-size: 1.05rem;
    font-weight: 600;
    max-width: 440px;
    margin-inline: auto;
  }

  .location-tags {
    display: flex;
    gap: .6rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1.5rem;
  }
  .tag {
    background: white;
    border: 2px solid #ede9fe;
    border-radius: 2rem;
    padding: .35rem .9rem;
    font-size: .8rem;
    font-weight: 800;
    color: #5b21b6;
  }
</style>
