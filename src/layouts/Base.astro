---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Einhorn-Wasser-Sommerfest 🦄' } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>
<body class="locked">
  <slot />

  <footer>
    Made with 💜 for Alva &amp; Laila · Sommer 2026
  </footer>

  <script>
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>
</body>
</html>

<style>
  footer {
    background: var(--dark);
    text-align: center;
    padding: 1.4rem 1rem;
    font-size: .78rem;
    font-weight: 700;
    color: rgba(255,255,255,.2);
  }
</style>
